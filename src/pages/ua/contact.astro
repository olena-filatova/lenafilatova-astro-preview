---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactBody from '../../components/ContactBody.astro';
import { CONTACT } from '../../data/site.js';
const c = CONTACT.ua;
---
<BaseLayout lang="ua" title={c.seoTitle} description={c.seoDesc} canonical="/ua/contact" alternates={{ en: "/contact", ua: "/ua/contact" }}>
  <ContactBody c={c} />
</BaseLayout>
