---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AboutBody from '../../components/AboutBody.astro';
import { ABOUT } from '../../data/site.js';
const c = ABOUT.ua;
const jsonld = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  mainEntity: {
    '@type': 'Person',
    name: 'Lena Filatova',
    description: c.seoDesc,
    url: 'https://lenafilatova.co.uk/ua/about',
  },
};
---
<BaseLayout lang="ua" title={c.seoTitle} description={c.seoDesc} canonical="/ua/about" alternates={{ en: "/about", ua: "/ua/about" }} ogImage={c.ogImage} jsonld={jsonld}>
  <AboutBody c={c} lang="ua" />
</BaseLayout>
