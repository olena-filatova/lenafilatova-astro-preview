---
import BaseLayout from "../layouts/BaseLayout.astro";
import LegalBody from "../components/LegalBody.astro";
import { LEGAL } from "../data/site.js";
const c = LEGAL.refunds.en;
---
<BaseLayout lang="en" title={c.seoTitle} description={c.seoDesc} canonical="/refunds" alternates={{ en: "/refunds", ua: "/ua/refunds" }}>
  <LegalBody c={c} />
</BaseLayout>
