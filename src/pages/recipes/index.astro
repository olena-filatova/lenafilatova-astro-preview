---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RecipeHubBody from '../../components/RecipeHubBody.astro';
const B = import.meta.env.BASE_URL;
const title = 'Low-GI Recipes — Lena Filatova';
const description = 'Blood-sugar-friendly low-GI recipes for women 40+ — sugar-free bakes, low-carb mains and desserts, in English and Ukrainian.';
---
<BaseLayout
  lang="en"
  title={title}
  description={description}
  canonical="/recipes/" alternates={{ en: "/recipes/", ua: "/ua/recipes/" }}
  showList={true}
  enHref={`${B}recipes/`}
  uaHref={`${B}ua/recipes/`}>
  <RecipeHubBody lang="en" />
</BaseLayout>
