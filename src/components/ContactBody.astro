---
import { BOOKING_EMBED, CONTACT_ENDPOINT } from '../data/site.js';
const { c } = Astro.props;
---
<section class="hero contact">
  <div class="wrap grid">
    <div class="col-left">
      <p class="kicker">{c.kicker}</p>
      <h1>{c.h1}</h1>
      <p class="lead">{c.lead}</p>

      <div class="notice">{c.disclaimer}</div>

      <h2 class="steps-title">{c.stepsTitle}</h2>
      <ol class="steps-list">
        {c.steps.map((s, i) => (
          <li>
            <span class="num">{i + 1}</span>
            <div><strong>{s.h}</strong><p>{s.p}</p></div>
          </li>
        ))}
      </ol>

      <p class="reach">{c.instagram} <a href="https://www.instagram.com/lena.filatova/">@lena.filatova</a></p>
      <p class="reach">{c.emailLabel} <a href="mailto:lena@lenafilatova.co.uk">lena@lenafilatova.co.uk</a></p>
    </div>

    <div class="col-right">
      <div class="contact-card">
        <div class="tabs" role="tablist">
          <button class="tab" data-tab="call" aria-selected="false">{c.tabCall}</button>
          <button class="tab is-active" data-tab="msg" aria-selected="true">{c.tabMsg}</button>
        </div>

        <div class="panel" data-panel="call" hidden>
          <h3 class="call-heading">{c.callHeading}</h3>
          <iframe src={BOOKING_EMBED} title={c.callHeading} loading="lazy" style="border:0" width="100%" height="600"></iframe>
        </div>

        <div class="panel" data-panel="msg">
          <!-- Posts to the same Google Apps Script that emails Lena (type=message). -->
          <form class="cform" action={CONTACT_ENDPOINT} method="post">
            <input type="hidden" name="type" value="message" />
            <label>{c.fName}<input type="text" name="name" required /></label>
            <label>{c.fEmail}<input type="email" name="email" required /></label>
            <label>{c.fMsg}<textarea name="message" rows="5" required></textarea></label>
            <button type="submit" class="btn full">{c.fSubmit}</button>
          </form>
          <p class="form-sent" hidden>{c.fSent}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Tiny tab toggle for the Book-a-call / Send-a-message card.
  document.querySelectorAll('.contact-card').forEach((card) => {
    const tabs = card.querySelectorAll('.tab');
    const panels = card.querySelectorAll('.panel');
    tabs.forEach((tab) => tab.addEventListener('click', () => {
      const key = tab.getAttribute('data-tab');
      tabs.forEach((t) => { const on = t === tab; t.classList.toggle('is-active', on); t.setAttribute('aria-selected', String(on)); });
      panels.forEach((p) => { p.hidden = p.getAttribute('data-panel') !== key; });
    }));
  });

  // Submit the message form to the Apps Script endpoint (no-cors, fire-and-forget,
  // same as the live site) and show the confirmation.
  document.querySelectorAll('.cform').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type=submit]');
      if (btn) btn.disabled = true;
      try {
        await fetch(form.action, { method: 'POST', mode: 'no-cors', body: new URLSearchParams(new FormData(form)) });
      } catch (_) { /* no-cors: response is opaque, submission still goes through */ }
      form.hidden = true;
      const sent = form.parentElement?.querySelector('.form-sent');
      if (sent) sent.hidden = false;
    });
  });
</script>
