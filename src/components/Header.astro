---
// Shared site header. Built ONCE — every page reuses it.
// Props:
//   lang     — 'en' | 'ua'
//   showList — when true, render the recipe shopping-list button (#listBtn)
//   enHref / uaHref — where the EN/UA toggle points (defaults to About).
//     Recipe pages pass their own counterpart so the toggle keeps the recipe.
import { NAV } from '../data/site.js';
const { lang = 'en', showList = false, enHref, uaHref } = Astro.props;
const t = NAV[lang];
const B = import.meta.env.BASE_URL;                 // '/…preview/' now, '/' at root
const L = lang === 'ua' ? `${B}ua/` : B;            // language-scoped base
const enTo = enHref || `${B}about/`;
const uaTo = uaHref || `${B}ua/about/`;
---
<header class="site-header">
  <div class="wrap inner">
    <a class="brand" href={L}><span class="mark">lf</span>Lena Filatova</a>
    <nav class="site-nav">
      <a href={`${L}blog/`}>{t.blog}</a>
      <a href={`${L}resources/`}>{t.resources}</a>
      <a href={`${L}recipes/`}>{t.recipes}</a>
      <a href={`${L}about/`}>{t.about}</a>
      <a href={`${L}contact/`}>{t.contact}</a>
    </nav>
    <div class="header-actions">
      <span class="lang">
        <a href={enTo} class={lang === 'en' ? 'on' : ''}>EN</a>
        <a href={uaTo} class={lang === 'ua' ? 'on' : ''}>UA</a>
      </span>
      {showList ? (
        <button class="list-btn" id="listBtn" aria-label="Shopping list" title="Shopping list">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><path d="M9 13l2 2 4-4"/></svg>
          <span class="list-badge" id="listBadge">0</span>
        </button>
      ) : (
        <a class="btn" href={`${L}contact/`}>{t.subscribe}</a>
      )}
    </div>
  </div>
</header>
