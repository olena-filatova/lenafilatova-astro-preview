---
import { NAV, FOOTER, SOCIALS, LEGAL_SLUGS } from '../data/site.js';
const { lang = 'en' } = Astro.props;
const t = FOOTER[lang];
const n = NAV[lang];
const B = import.meta.env.BASE_URL;
const L = lang === 'ua' ? `${B}ua/` : B;
// legalLinks and these slugs are in the same order (privacy, cookies, terms, refunds, accessibility).
const legalSlugs = Object.values(LEGAL_SLUGS);
// Footer category links open the blog with that filter pre-selected (?cat=…).
// Same order as FOOTER.cats; null = no matching blog category, plain blog link.
const catKeys = ['perimenopause', 'nutrition', null, 'diabetes'];
const catHref = (i) => `${L}blog/${catKeys[i] ? `?cat=${catKeys[i]}` : ''}`;
---
<footer class="site-footer">
  <div class="wrap">
    <div class="top">
      <div>
        <a class="brand" href={L}><span class="mark">lf</span>Lena Filatova</a>
        <p class="blurb">{t.blurb}</p>
        <h4 style="margin-top:20px">{t.follow}</h4>
        <div class="socials">
          {SOCIALS.map((s) => (
            <a href={s.href} aria-label={s.name} target="_blank" rel="noopener">{s.name[0]}</a>
          ))}
        </div>
      </div>
      <div>
        <h4>{t.explore}</h4>
        <ul>
          <li><a href={`${L}blog/`}>{n.blog}</a></li>
          <li><a href={`${L}resources/`}>{n.resources}</a></li>
          <li><a href={`${L}recipes/`}>{n.recipes}</a></li>
          <li><a href={`${L}about/`}>{n.about}</a></li>
          <li><a href={`${L}contact/`}>{n.contact}</a></li>
        </ul>
      </div>
      <div>
        <h4>{t.categories}</h4>
        <ul>{t.cats.map((c, i) => <li><a href={catHref(i)}>{c}</a></li>)}</ul>
      </div>
      <div>
        <h4>{t.legal}</h4>
        <ul>{t.legalLinks.map((c, i) => <li><a href={`${L}${legalSlugs[i]}/`}>{c}</a></li>)}</ul>
        <h4 style="margin-top:20px">{t.contact}</h4>
        <ul><li><a href="mailto:lena@lenafilatova.co.uk">lena@lenafilatova.co.uk</a></li></ul>
      </div>
    </div>
    <div class="legal">
      <p>{t.company}</p>
      <p>{t.disclaimer}</p>
    </div>
  </div>
</footer>
