---
// Cookie banner + consent-gated GA4 — same GA_ID and localStorage keys as the
// live Divhunt site (lf_cookie: "accepted" | "declined"), so returning
// visitors' choices carry over and analytics history stays continuous.
// GA loads ONLY after acceptance; declining stores the choice and loads nothing.
const { lang = 'en' } = Astro.props;
const t = lang === 'ua'
  ? { text: 'Цей сайт використовує файли cookie, щоб працювати та розуміти, як ним користуються.', accept: 'Прийняти', decline: 'Відхилити', policy: 'Політика cookie' }
  : { text: "This site uses cookies to keep it working and to understand how it's used.", accept: 'Accept', decline: 'Decline', policy: 'Cookie Policy' };
const B = import.meta.env.BASE_URL;
const L = lang === 'ua' ? `${B}ua/` : B;
const policyHref = `${L}cookies/`;
---
<div class="cookie-bar" id="cookieBar" hidden>
  <div class="cookie-inner">
    <p>{t.text} <a href={policyHref}>{t.policy}</a></p>
    <div class="cookie-actions">
      <button class="btn" id="cookieAccept">{t.accept}</button>
      <button class="cookie-decline" id="cookieDecline">{t.decline}</button>
    </div>
  </div>
</div>

<script is:inline defer src={`${B}cookie-consent.js`}></script>

<style>
  /* display:flex below would override the hidden attribute's UA display:none,
     leaving the bar visible after Accept/Decline — this rule must win. */
  .cookie-bar[hidden] { display: none !important; }
  /* Full-width bar flush to the bottom edge of the screen (mobile-first). */
  .cookie-bar {
    position: fixed; left: 0; right: 0; bottom: 0; z-index: 100;
    background: var(--card); border-top: 1px solid var(--line);
    padding: 12px 16px; padding-bottom: calc(12px + env(safe-area-inset-bottom));
    box-shadow: 0 -6px 24px rgba(51, 27, 51, 0.12);
  }
  /* Inner wrapper keeps the content readable-width and centred on wide screens
     while the bar background still spans edge to edge. */
  .cookie-inner {
    width: 100%; max-width: 960px; margin: 0 auto;
    display: flex; flex-wrap: wrap; gap: 10px 16px; align-items: center; justify-content: space-between;
  }
  .cookie-bar p { margin: 0; font-size: 13.5px; line-height: 1.5; color: var(--muted); flex: 1 1 240px; min-width: 0; }
  .cookie-bar p a { color: var(--accent); font-weight: 600; }
  .cookie-actions { display: flex; gap: 8px; align-items: center; margin-left: auto; }
  .cookie-bar .btn { padding: 9px 18px; font-size: 13.5px; }
  .cookie-decline { border: none; background: transparent; color: var(--muted); font-family: var(--font-body); font-size: 13.5px; font-weight: 600; cursor: pointer; padding: 9px 10px; }
</style>
