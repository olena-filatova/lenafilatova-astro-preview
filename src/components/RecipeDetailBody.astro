---
// One recipe, fully server-rendered in the page's language (EN or UA).
// Static content lives in the HTML (SEO); a small inline script handles the
// servings scaler, step check-off, and exposes window.LF_RECIPE so the shared
// recipes.js can wire "add to shopping list" + share.
import { PUBLISHED } from '../data/recipes.js';
import { CAT_PAGE, DIET, isHeader, giBand, GI_DISCLAIMER, imagesOf } from '../data/recipes-lib.js';
import '../styles/recipes.css';

const { R, lang = 'en' } = Astro.props;
const B = import.meta.env.BASE_URL;
const HUB = lang === 'ua' ? `${B}ua/recipes/` : `${B}recipes/`;
const IMG = `${B}recipes/images/`;
const l = lang;

const T = {
  back: l === 'ua' ? '← Усі рецепти з низьким ГІ' : '← All Low-GI recipes',
  lowGi: l === 'ua' ? 'Низький ГІ' : 'Low GI',
  why: l === 'ua' ? 'Чому це Low GI' : "Why it's Low GI",
  ingredients: l === 'ua' ? 'Інгредієнти' : 'Ingredients',
  servings: l === 'ua' ? 'Порції' : 'Servings',
  prep: l === 'ua' ? 'Підготовка' : 'Prep',
  cook: l === 'ua' ? 'Готування' : 'Cook',
  gi: l === 'ua' ? 'ГІ' : 'GI',
  method: l === 'ua' ? 'Спосіб приготування' : 'Method',
  methodSub: l === 'ua' ? 'Торкніться кроку, коли виконали.' : "Tap a step when it's done.",
  nutrition: l === 'ua' ? 'Поживність' : 'Nutrition',
  tip: l === 'ua' ? 'Порада' : 'Tip',
  more: l === 'ua' ? 'Більше рецептів з низьким ГІ' : 'More Low-GI recipes',
  print: l === 'ua' ? 'Друк рецепта' : 'Print recipe',
  share: l === 'ua' ? 'Поділитися' : 'Share',
  shareThis: l === 'ua' ? 'Поділитися рецептом' : 'Share this recipe',
  shareNative: l === 'ua' ? 'Поділитися…' : 'Share…',
  copyLink: l === 'ua' ? 'Копіювати посилання' : 'Copy link',
  emailPh: l === 'ua' ? 'Надіслати рецепт на пошту' : 'Send recipe to email',
  alsoEmail: l === 'ua' ? 'Також надсилати мені нові рецепти й новини' : 'Also email me new recipes & news',
  sendRecipe: l === 'ua' ? 'Надіслати рецепт' : 'Send recipe',
  recipeSent: l === 'ua' ? 'Рецепт надіслано — перевірте пошту' : 'Recipe sent — check your inbox',
  addList: l === 'ua' ? 'Додати до списку покупок' : 'Add to shopping list',
  footNote: l === 'ua'
    ? 'Показники ГІ є орієнтовними й не замінюють персональну медичну чи дієтичну консультацію.'
    : 'GI figures are estimates for general guidance and are not a substitute for personalised medical or dietary advice.',
};

const band = giBand(R.gi, l);
const imgs = imagesOf(R);
const primary = imgs[0];
const others = PUBLISHED.filter((x) => x.slug !== R.slug).slice(0, 3);

// Payload the client script needs (both languages for the shopping list).
const rec = {
  id: R.slug,
  title: R.title,
  why: R.why,
  serves: R.meta?.serves || { en: '', ua: '' },
  ingredients: R.ingredients,
  lang: l,
};
---
<script is:inline define:vars={{
  altHref: l === 'ua' ? `${B}recipes/${R.slug}/` : `${B}ua/recipes/${R.slug}/`,
  otherLang: l === 'ua' ? 'en' : 'ua',
}}>
  if (new RegExp('[?&]lang=' + otherLang).test(location.search)) location.replace(altHref);
</script>

<div class="rx">
  <a class="back" href={HUB}>{T.back}</a>
  <h1>{R.title[l]}</h1>

  <div class="tags">
    <span class="tag">{T.lowGi}</span>
    <span class="tag">{CAT_PAGE[R.cat][l]}</span>
    {(R.tags || []).filter((t) => DIET[t]).map((t) => <span class="tag">{DIET[t][l]}</span>)}
  </div>

  <div class="photo hero"><img src={`${IMG}${primary}`} alt={R.title[l]} /></div>

  <div class="meta">
    {R.meta?.prep && <div><span class="k">{T.prep}</span><span class="v">{R.meta.prep[l]}</span></div>}
    {R.meta?.cook && <div><span class="k">{T.cook}</span><span class="v">{R.meta.cook[l]}</span></div>}
    {R.meta?.serves && <div><span class="v" id="metaServes">{R.meta.serves[l]}</span></div>}
    {band && (
      <div><span class="k">{T.gi}</span><span class="v">~{R.gi} <span style={`font-size:13px;font-weight:600;color:${band.color};`}>· {band.label}</span></span></div>
    )}
  </div>

  <div class="notes" id="rWhy" style="margin-bottom:30px;">
    <h3>{T.why}</h3>
    <p>{R.why[l]}</p>
  </div>

  <div class="recipe-grid">
    <aside class="ing-card">
      <div class="sec-head"><h2>{T.ingredients}</h2></div>
      <div class="scaler">
        <span class="label">{T.servings}</span>
        <div class="stepper">
          <button id="minus" aria-label="Fewer servings">−</button>
          <span class="count" id="servings"></span>
          <button id="plus" aria-label="More servings">+</button>
        </div>
        <span class="hint" id="scaleHint"></span>
      </div>
      <ul class="ingredients" id="ingredients">
        {R.ingredients[l].map((it) => (
          isHeader(it)
            ? <li class="ing-section">{it.replace(/—/g, '').trim()}</li>
            : <li><label class="check"><input type="checkbox" /><span class="box"></span><span class="ing-text">{it}</span></label></li>
        ))}
      </ul>

      <div class="add-row">
        <button class="btn primary full" id="addListBtn"
          data-add-en="Add to shopping list" data-add-ua="Додати до списку покупок"
          data-added-en="Added to shopping list" data-added-ua="Додано до списку покупок">
          <span class="i-plus"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><path d="M12 11v6M9 14h6"/></svg></span>
          <span class="i-check" style="display:none"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg></span>
          <span class="lbl">{T.addList}</span>
        </button>
      </div>

      <div class="pf-row">
        <button class="btn" id="printBtn">{T.print}</button>
        <button class="btn" id="shareToggle">{T.share}</button>
      </div>

      <div class="share-panel" id="sharePanel">
        <div class="share-kicker">{T.shareThis}</div>
        <div class="share-two">
          <button class="btn" id="shNative">{T.shareNative}</button>
          <button class="btn" id="shCopy"><span class="lbl">{T.copyLink}</span></button>
        </div>
        <form class="share-form" id="shareForm">
          <input type="email" id="shareEmail" placeholder={T.emailPh} />
          <label class="opt"><input type="checkbox" id="shareOpt" checked /><span>{T.alsoEmail}</span></label>
          <button type="submit" class="btn primary full">{T.sendRecipe}</button>
          <div class="confirm" id="shareSent"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg><span>{T.recipeSent}</span></div>
        </form>
      </div>
    </aside>

    <div class="recipe-main">
      <div class="section">
        <h2>{T.method}</h2>
        <p class="sub">{T.methodSub}</p>
        <div class="progress-wrap"><div class="bar"><i id="barFill"></i></div><span class="pct" id="stepPct"></span></div>
        <ol class="steps" id="steps">
          {R.method[l].map((st, i) => (
            <li id={`step-${i + 1}`}><span class="num"></span><span class="step-text">{st}
              {R.stepImgs?.[i + 1] && <img class="step-photo" src={`${IMG}${R.stepImgs[i + 1]}`} alt={`${R.title[l]} — ${l === 'ua' ? 'крок' : 'step'} ${i + 1}`} loading="lazy" width="900" height="900" />}
            </span></li>
          ))}
        </ol>
      </div>

      {R.nutrition && (
        <div class="section">
          <h2>{T.nutrition}</h2>
          <div class="nutri-card"><div class="gl-note"><b>{R.nutrition[l]}</b><span style="display:block;margin-top:8px;font-size:12.5px;color:var(--muted);">{GI_DISCLAIMER[l]}</span></div></div>
        </div>
      )}

      {R.note && (
        <div class="section">
          <div class="notes"><h3>{T.tip}</h3><p>{R.note[l]}</p></div>
        </div>
      )}
    </div>
  </div>

  <section class="suggest section">
    <h2>{T.more}</h2>
    <div class="cards">
      {others.map((x) => (
        <a class="rcard" href={`${HUB}${x.slug}/`}>
          <div class="thumb"><img src={`${IMG}${x.img}`} alt="" /><span class="mini-gi">{T.lowGi}</span></div>
          <div class="body"><div class="title">{x.title[l]}</div><div class="cmeta"><span>{x.meta.serves[l]}</span></div></div>
        </a>
      ))}
    </div>
  </section>

  <p class="foot-note">{T.footNote}</p>
</div>

<script is:inline define:vars={{ rec, lang: l }}>
  window.LF_LANG = lang;
  (function () {
    var l = lang;
    /* ---- quantity scaling (grams, cups, tsp, fractions, mixed like 1½) ---- */
    var FRC = '½¼¾⅓⅔⅛⅜⅝⅞⅕⅖⅗⅘';
    var FR = { '½':0.5,'¼':0.25,'¾':0.75,'⅓':1/3,'⅔':2/3,'⅛':0.125,'⅜':0.375,'⅝':0.625,'⅞':0.875,'⅕':0.2,'⅖':0.4,'⅗':0.6,'⅘':0.8 };
    var NUM = new RegExp('(\\d+\\s*[' + FRC + '])|([' + FRC + '])|(\\d+[.,]\\d+)|(\\d+)', 'g');
    function parseTok(t) {
      t = t.trim();
      var mm = t.match(new RegExp('^(\\d+)\\s*([' + FRC + '])$'));
      if (mm) return parseInt(mm[1], 10) + FR[mm[2]];
      if (t.length === 1 && FR[t] != null) return FR[t];
      if (/^\d+[.,]\d+$/.test(t)) return parseFloat(t.replace(',', '.'));
      return parseInt(t, 10);
    }
    function fmtQty(v) {
      if (v <= 0) return '0';
      var whole = Math.floor(v + 1e-9), frac = v - whole;
      var opts = [[0,''],[0.25,'¼'],[1/3,'⅓'],[0.5,'½'],[2/3,'⅔'],[0.75,'¾'],[1,'']];
      var best = opts[0], bd = 2;
      opts.forEach(function (o) { var d = Math.abs(frac - o[0]); if (d < bd) { bd = d; best = o; } });
      if (bd > 0.08) return String(Math.round(v * 10) / 10);
      if (best[0] === 1) { whole += 1; best = opts[0]; }
      if (whole === 0) return best[1] || '0';
      return whole + (best[1] || '');
    }
    function scaleText(text, f) { return f === 1 ? text : text.replace(NUM, function (m) { return fmtQty(parseTok(m) * f); }); }
    function isHeader(s) { return /^—/.test(s); }
    function cleanItems(arr, f) { return arr.filter(function (s) { return !isHeader(s); }).map(function (s) { return scaleText(s, f); }); }

    function baseServes() { var mm = (rec.serves.en || '').match(/\d+/); return mm ? parseInt(mm[0], 10) : 1; }
    var base = baseServes(), mult = 1;

    var ingUl = document.getElementById('ingredients');
    var metaServes = document.getElementById('metaServes');
    var servingsCount = document.getElementById('servings');
    var minus = document.getElementById('minus'), plus = document.getElementById('plus');

    function esc(s) { return String(s).replace(/[&<>"]/g, function (c) { return ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;' })[c]; }); }
    function renderIngredients() {
      var f = mult;
      ingUl.innerHTML = '';
      rec.ingredients[l].forEach(function (it) {
        var li = document.createElement('li');
        if (isHeader(it)) { li.className = 'ing-section'; li.textContent = it.replace(/—/g, '').trim(); }
        else li.innerHTML = '<label class="check"><input type="checkbox"><span class="box"></span><span class="ing-text">' + esc(scaleText(it, f)) + '</span></label>';
        ingUl.appendChild(li);
      });
      if (metaServes && rec.serves[l]) metaServes.textContent = scaleText(rec.serves[l], f);
      servingsCount.textContent = base * mult;
      minus.disabled = mult <= 1;
      plus.disabled = mult >= 8;
    }
    minus.addEventListener('click', function () { if (mult > 1) { mult--; renderIngredients(); } });
    plus.addEventListener('click', function () { if (mult < 8) { mult++; renderIngredients(); } });
    renderIngredients();

    /* ---- method step check-off + progress ---- */
    var steps = [].slice.call(document.querySelectorAll('#steps li'));
    function updateProgress() {
      var done = steps.filter(function (s) { return s.classList.contains('done'); }).length;
      document.getElementById('barFill').style.width = (steps.length ? done / steps.length * 100 : 0) + '%';
      document.getElementById('stepPct').textContent = (l === 'ua') ? ('Виконано ' + done + ' з ' + steps.length) : (done + ' of ' + steps.length + ' done');
    }
    steps.forEach(function (li) { li.addEventListener('click', function () { li.classList.toggle('done'); updateProgress(); }); });
    updateProgress();

    document.getElementById('printBtn').addEventListener('click', function () { window.print(); });

    /* ---- expose recipe for recipes.js (add-to-list + share) ---- */
    window.LF_RECIPE = {
      id: rec.id, title_en: rec.title.en, title_ua: rec.title.ua, lead_en: rec.why.en, lead_ua: rec.why.ua,
      snapshot: function () {
        var f = mult;
        return { id: rec.id, title_en: rec.title.en, title_ua: rec.title.ua,
          serves_en: scaleText(rec.serves.en, f), serves_ua: scaleText(rec.serves.ua, f),
          items_en: cleanItems(rec.ingredients.en, f), items_ua: cleanItems(rec.ingredients.ua, f) };
      }
    };
  })();
</script>
<script is:inline src={`${B}recipes.js`}></script>
