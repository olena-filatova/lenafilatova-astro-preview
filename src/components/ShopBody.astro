---
// Shop — "coming soon" storefront (see shop.js for why there's no cart or
// pricing). Two product cards carry a Coming-soon badge and a get-notified
// CTA; the coaching card is live and points at the contact page.
import { SHOP } from '../data/shop.js';

const { lang = 'en' } = Astro.props;
const t = SHOP[lang];
const B = import.meta.env.BASE_URL;
const L = lang === 'ua' ? `${B}ua/` : B;
const img = (src) => B.replace(/\/$/, '') + src;
---
<section class="hero shop-hero">
  <div class="wrap">
    <p class="kicker">{t.kicker}</p>
    <h1>{t.h1}</h1>
    <p class="lead">{t.lead}</p>
  </div>
</section>

<section class="shop-list">
  <div class="wrap">
    <div class="shop-grid">
      {t.items.map((p, i) => (
        <article class="pcard">
          <div class="pphoto">
            <img src={img(SHOP.imgs[i])} alt={p.title} loading="lazy" />
            {!p.available && <span class="psoon">{t.soon}</span>}
          </div>
          <div class="pbody">
            <p class="ptag">{p.tag}</p>
            <h2>{p.title}</h2>
            <p class="pdesc">{p.body}</p>
            <p class="pformat">{p.format}</p>
            <ul class="pinside">
              {p.inside.map((li) => <li>{li}</li>)}
            </ul>
            {p.available
              ? <a class="btn" href={`${L}contact/`}>{t.coachCta}</a>
              : <a class="btn ghost-dark" href={`${L}contact/`}>{t.notify}</a>}
          </div>
        </article>
      ))}
    </div>
    <p class="shop-note">{t.note}</p>
  </div>
</section>

<style>
  .shop-hero { padding: 56px 0 10px; }
  .shop-hero h1 { font-size: clamp(30px, 4.2vw, 44px); letter-spacing: -0.5px; }
  .shop-hero .lead { max-width: 640px; margin: 14px 0 0; font-size: 17px; color: var(--muted); }
  .shop-list { padding: 30px 0 64px; }
  .shop-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
  @media (max-width: 900px) { .shop-grid { grid-template-columns: 1fr; max-width: 560px; } }
  .pcard { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); overflow: hidden; display: flex; flex-direction: column; }
  .pphoto { position: relative; aspect-ratio: 4 / 3; }
  .pphoto img { width: 100%; height: 100%; object-fit: cover; }
  .psoon { position: absolute; top: 12px; left: 12px; font-size: 10.5px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: #fff; background: var(--ink); padding: 4px 10px; border-radius: 999px; }
  .pbody { padding: 22px 24px 26px; display: flex; flex-direction: column; gap: 10px; flex: 1; }
  .ptag { font-size: 11.5px; font-weight: 700; letter-spacing: 1.3px; text-transform: uppercase; color: var(--accent); margin: 0; }
  .pbody h2 { font-size: 23px; font-weight: 600; letter-spacing: -0.2px; }
  .pdesc { margin: 0; font-size: 15px; line-height: 1.6; color: var(--muted); }
  .pformat { margin: 0; font-size: 13px; font-weight: 600; color: #7A6675; }
  .pinside { margin: 0 0 8px; padding: 0 0 0 18px; font-size: 14px; line-height: 1.7; color: var(--body); flex: 1; }
  .pbody .btn { align-self: flex-start; }
  .btn.ghost-dark { background: transparent; border: 1.5px solid var(--line); color: var(--ink); }
  .btn.ghost-dark:hover { border-color: var(--accent); color: var(--accent); filter: none; }
  .shop-note { margin: 30px auto 0; max-width: 640px; text-align: center; font-size: 14.5px; line-height: 1.6; color: #7A6675; }
</style>
