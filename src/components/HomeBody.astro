---
import { HOME, RESOURCES, CONTACT_ENDPOINT } from '../data/site.js';
import { POSTS } from '../data/blog.js';
const { lang = 'en' } = Astro.props;
const t = HOME[lang];
const B = import.meta.env.BASE_URL;
const L = lang === 'ua' ? `${B}ua/` : B;
const resourcesHref = `${L}resources/`;
const blogHref = `${L}blog/`;
const recipesAllHref = `${L}recipes/`;
const img = (src) => B.replace(/\/$/, '') + src;

// Latest article: computed from the blog data itself (not hand-copied) so a
// newly published post is always what gets featured here.
const latestPost = [...POSTS].filter((p) => !p.comingSoon).sort((a, b) => b.date.localeCompare(a.date))[0];
const latestPostT = latestPost[lang];

const featuredRecipe = HOME.recipe;

// Featured resource: the food calculator
const featuredResource = RESOURCES.cards[0];
const featuredResourceT = featuredResource[lang];
const featuredResourceRaw = lang === 'ua' ? featuredResource.hrefUa : featuredResource.href;
const featuredResourceHref = featuredResourceRaw.startsWith('/') ? B.replace(/\/$/, '') + featuredResourceRaw : featuredResourceRaw;
---
<!-- HERO -->
<section class="hero home">
  <div class="wrap grid">
    <div>
      <p class="kicker">{t.heroKicker}</p>
      <h1>{t.heroH1}</h1>
      <p class="lead">{t.heroLead}</p>
      <div class="hero-cta">
        <a class="btn" href={resourcesHref}>{t.heroCta1}</a>
        <a class="btn ghost" href={blogHref}>{t.heroCta2}</a>
      </div>
      <p class="hero-note"><span class="dot"></span>{t.heroNote}</p>
    </div>
    <div class="photo">
      <img
        src={img('/images/lena-filatova-womens-health-coach-over-40.jpg')}
        alt={lang === 'ua'
          ? 'Lena Filatova — коуч з жіночого здоров’я та харчування для жінок 40+'
          : "Lena Filatova, women's health and nutrition coach for women over 40"}
        fetchpriority="high"
        decoding="async"
      />
    </div>
  </div>
</section>

<!-- FROM THE BLOG: latest article -->
<section class="section">
  <div class="wrap">
    <div class="section-head">
      <div><h2>{t.blogTitle}</h2><p class="section-sub">{t.blogSub}</p></div>
      <a class="see-all" href={blogHref}>{t.blogAll}</a>
    </div>
    <a class="feature-card" href={`${L}blog/${latestPost.slug}/`}>
      <div class="feature-photo"><img src={img(latestPost.image)} alt={latestPostT.title} loading="lazy" /></div>
      <div class="feature-body">
        <span class="mini-cat">{latestPostT.cat}</span>
        <h3>{latestPostT.title}</h3>
        <p class="feature-desc">{latestPostT.excerpt}</p>
        <p class="feature-meta">{latestPostT.meta}</p>
        <span class="btn">{t.blogCta}</span>
      </div>
    </a>
  </div>
</section>

<!-- FROM MY KITCHEN: one recipe -->
<section class="section">
  <div class="wrap">
    <div class="section-head">
      <div><h2>{t.recipesTitle}</h2><p class="section-sub">{t.recipesSub}</p></div>
      <a class="see-all" href={recipesAllHref}>{t.recipesAll}</a>
    </div>
    <a class="feature-card" href={`${L}recipes/${featuredRecipe.slug}/`}>
      <div class="feature-photo"><img src={img(featuredRecipe.img)} alt={featuredRecipe.title[lang]} loading="lazy" /></div>
      <div class="feature-body">
        <span class="mini-cat">{featuredRecipe.cat[lang]}</span>
        <h3>{featuredRecipe.title[lang]}</h3>
        <p class="feature-desc">{featuredRecipe.desc[lang]}</p>
        <p class="feature-meta">GI {featuredRecipe.gi} · {featuredRecipe.carbs}{lang === 'ua' ? ' ' : 'g '}{t.carbs}</p>
        <span class="btn">{t.recipeCta}</span>
      </div>
    </a>
  </div>
</section>

<!-- FREE TOOLS & GUIDES: one resource -->
<section class="section">
  <div class="wrap">
    <div class="section-head">
      <div><h2>{t.resourcesTitle}</h2><p class="section-sub">{t.resourcesSub}</p></div>
      <a class="see-all" href={resourcesHref}>{t.resourcesAll}</a>
    </div>
    <div class="feature-resource">
      <a class="rcard" href={featuredResourceHref}>
        <div class="rband" style={`background:${featuredResource.band}`}>
          <span style={`color:${featuredResource.head}`}>{featuredResourceT.band}</span>
        </div>
        <div class="rbody">
          <p class="rkicker">{featuredResourceT.kicker}</p>
          <h3>{featuredResourceT.title}</h3>
          <p class="rdesc">{featuredResourceT.desc}</p>
          <span class="rcta">{featuredResourceT.cta}</span>
        </div>
      </a>
    </div>
  </div>
</section>

<!-- WHAT I HELP WITH -->
<section class="section">
  <div class="wrap">
    <h2>{t.helpTitle}</h2>
    <p class="section-sub">{t.helpSub}</p>
    <div class="help-grid">
      {t.help.map((c, i) => (
        <div class="help-card" style={`background:${HOME.helpColors[i]}`}>
          <span class="help-num" style={`color:${HOME.helpNums[i]}`}>{String(i + 1).padStart(2, '0')}</span>
          <div class="help-text">
            <h3>{c.h}</h3>
            <p>{c.p}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- NEWSLETTER -->
<section class="section newsletter">
  <div class="wrap nl-box">
    <h2>{t.nlTitle}</h2>
    <p class="section-sub">{t.nlSub}</p>
    <form class="nlform" action={CONTACT_ENDPOINT} method="post">
      <input type="hidden" name="source" value="newsletter" />
      <input type="hidden" name="lang" value={lang} />
      <div class="nl-row">
        <input type="email" name="email" placeholder={t.nlEmail} required />
        <button type="submit" class="btn">{t.nlBtn}</button>
      </div>
      <label class="nl-consent"><input type="checkbox" required /> {t.nlConsent}</label>
    </form>
    <p class="nl-sent form-sent" hidden>{t.nlSent}</p>
  </div>
</section>

<script>
  document.querySelectorAll('.nlform').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type=submit]');
      if (btn) btn.disabled = true;
      try {
        await fetch(form.action, { method: 'POST', mode: 'no-cors', body: new URLSearchParams(new FormData(form)) });
      } catch (_) {}
      form.hidden = true;
      const sent = form.parentElement?.querySelector('.nl-sent');
      if (sent) sent.hidden = false;
    });
  });
</script>
